import Hero from "@components/Hero.astro";
import HoursLocation from "@components/HoursLocation.astro";
import InquiryForm from "@components/InquiryForm.astro";
import MenuHighlights from "@components/MenuHighlights.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />
    <MenuHighlights />
    <About />
    <Catering />
    <HoursLocation />
    <InquiryForm />
  </main>
  <Footer />
</BaseLayout>
